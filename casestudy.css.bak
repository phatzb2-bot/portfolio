/* ================================================
   CASE STUDY SUBPAGE STYLES
   Swipe galleries, clean sections, responsive
   ================================================ */

/* ---------- Hero with Background Image ---------- */
.cs-hero {
    padding: 120px 0 80px;
    position: relative;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
}
.cs-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,14,0.75) 0%, rgba(10,10,14,0.92) 100%);
    z-index: 1;
}
.cs-hero .container {
    position: relative;
    z-index: 2;
}
.cs-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 40px;
    transition: color 0.3s;
}
.cs-hero__back:hover { color: #fff; }
.cs-hero__back-arrow { font-size: 1.2rem; }
.cs-hero__header { text-align: center; }
.cs-hero__label {
    display: inline-block;
    background: rgba(0,255,136,0.15);
    color: #00ff88;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 16px;
}
.cs-hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
}
.cs-hero__subtitle {
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: rgba(255,255,255,0.7);
    margin-bottom: 12px;
}
.cs-hero__tagline {
    font-style: italic;
    color: #00ff88;
    font-size: 1.1rem;
    text-shadow: 0 2px 10px rgba(0,255,136,0.3);
}

/* ---------- Overview Bar ---------- */
.cs-overview {
    padding: 40px 0;
    background: rgba(255,255,255,0.03);
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
}
.cs-overview__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
}
.cs-overview__item { text-align: center; }
.cs-overview__label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #00ff88;
    margin-bottom: 8px;
    font-weight: 600;
}
.cs-overview__value {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
}
.cs-overview__value small {
    display: block;
    color: rgba(255,255,255,0.4);
    font-size: 0.8em;
    margin-top: 2px;
}

/* ---------- Results ---------- */
.cs-results {
    padding: 60px 0 40px;
}
.cs-results__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
}
.cs-results__card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
}
.cs-results__card:hover {
    border-color: rgba(0,255,136,0.3);
    box-shadow: 0 8px 30px rgba(0, 255, 136, 0.06);
    transform: translateY(-2px);
}
.cs-results__icon { display: block; font-size: 1.6rem; margin-bottom: 12px; }
.cs-results__number {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #00ff88;
    margin-bottom: 8px;
}
.cs-results__label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
}
.cs-results__highlights {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
}
.cs-results__highlight {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 16px 20px;
}
.cs-results__highlight-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 2px; }
.cs-results__highlight p { color: rgba(255,255,255,0.75); line-height: 1.5; font-size: 0.9rem; }

/* ---------- FEEDBACK 7: Section Headers — Centered & Bold ---------- */
.cs-section {
    padding: 80px 0;
}
.cs-section--alt {
    background: rgba(255,255,255,0.02);
}
.cs-section__header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}
.cs-section__header--center {
    flex-direction: column;
    text-align: center;
    gap: 8px;
}
.cs-section__number {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #00ff88;
    letter-spacing: 2px;
}
.cs-section__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #fff;
}
.cs-text--lead {
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.8);
    margin-bottom: 32px;
}

/* ---------- FEEDBACK 2: Challenges — 5 cards on one row ---------- */
.cs-challenges__grid--row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
}
.cs-challenge {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s, transform 0.3s;
}
.cs-challenge:hover {
    border-color: rgba(0,255,136,0.3);
    transform: translateY(-4px);
}
.cs-challenge__icon { font-size: 1.8rem; margin-bottom: 16px; }
.cs-challenge h4 {
    font-size: 0.95rem;
    color: #fff;
    margin-bottom: 10px;
    font-weight: 600;
}
.cs-challenge p {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.5;
    flex: 1;
}

/* ---------- Subsection Titles ---------- */
.cs-subsection__title {
    font-size: 1.15rem;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    margin: 40px 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
}

/* ---------- Comparison Table ---------- */
.cs-comparison__table {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 32px;
}
.cs-comparison__row {
    display: grid;
    grid-template-columns: 120px 1fr 1fr;
    border-bottom: 1px solid rgba(255,255,255,0.06);
}
.cs-comparison__row:last-child { border-bottom: none; }
.cs-comparison__row--header {
    background: rgba(255,255,255,0.06);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}
.cs-comparison__cell {
    padding: 14px 16px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    border-right: 1px solid rgba(255,255,255,0.06);
}
.cs-comparison__cell:last-child { border-right: none; }
.cs-comparison__cell--label {
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    font-size: 0.8rem;
}
.cs-comparison__cell--highlight { color: #00ff88; }

/* ---------- Content Pillars 40-40-20 ---------- */
.cs-pillars { margin-bottom: 32px; }
.cs-pillar__item { margin-bottom: 16px; }
.cs-pillar__bar {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(0,255,136,0.2);
    border-radius: 8px;
    padding: 12px 16px;
    width: var(--pillar-width, 100%);
    max-width: 100%;
}
.cs-pillar__icon { font-size: 1.2rem; }
.cs-pillar__name { font-weight: 600; color: #fff; font-size: 0.9rem; }
.cs-pillar__pct { margin-left: auto; color: #00ff88; font-weight: 700; font-size: 1rem; }
.cs-pillar__desc {
    margin-top: 8px;
    padding-left: 16px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
}
.cs-pillar__item--accent .cs-pillar__bar { border-color: rgba(0,200,136,0.2); }
.cs-pillar__item--muted .cs-pillar__bar { border-color: rgba(255,255,255,0.1); }

/* ---------- FEEDBACK 3: Tiers merged with galleries ---------- */
.cs-tiers-with-gallery {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin-bottom: 32px;
}
.cs-tier-block {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 24px;
}
.cs-tier {
    margin-bottom: 16px;
}
.cs-tier__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
}
.cs-tier__badge {
    background: rgba(0,255,136,0.12);
    color: #00ff88;
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
}
.cs-tier__badge--accent {
    background: rgba(100,200,255,0.12);
    color: #64c8ff;
}
.cs-tier__badge--premium {
    background: rgba(255,200,100,0.12);
    color: #ffc864;
}
.cs-tier__pct {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #00ff88;
    margin-left: auto;
}
.cs-tier__speed {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
}
.cs-results__number--static {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #00ff88;
    margin-bottom: 8px;
}
.cs-tier p {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
}

/* ---------- Growth Hacks ---------- */
.cs-growth { display: flex; flex-direction: column; gap: 24px; }
.cs-growth__block {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 24px;
}
.cs-growth__heading {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 16px;
}
.cs-growth__content { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-items: start; }
.cs-growth__text { display: flex; flex-direction: column; gap: 12px; }
.cs-growth__point {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.5;
    padding-left: 16px;
    border-left: 2px solid rgba(0,255,136,0.3);
}

/* ---------- Swipe Gallery ---------- */
.swipe-gallery {
    margin-bottom: 24px;
}
.swipe-gallery__track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,255,136,0.3) transparent;
}
.swipe-gallery__track::-webkit-scrollbar { height: 6px; }
.swipe-gallery__track::-webkit-scrollbar-track { background: transparent; }
.swipe-gallery__track::-webkit-scrollbar-thumb { background: rgba(0,255,136,0.3); border-radius: 3px; }
.swipe-gallery__slide {
    flex: 0 0 280px;
    scroll-snap-align: start;
}
.swipe-gallery__slide img {
    width: 100%;
    height: 380px;
    object-fit: contain;
    border-radius: 12px;
    background: rgba(255,255,255,0.03);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
}
.swipe-gallery__slide img:hover {
    transform: scale(1.02);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
}
.swipe-gallery--compact .swipe-gallery__slide { flex: 0 0 240px; }
.swipe-gallery--compact .swipe-gallery__slide img { height: 320px; }

/* ---------- FEEDBACK 6: Partner gallery — no cropping ---------- */
.swipe-gallery--partner .swipe-gallery__slide {
    flex: 0 0 300px;
    text-align: center;
}
.swipe-gallery--partner .swipe-gallery__slide img {
    height: 420px;
    object-fit: contain;
    border-radius: 12px;
    background: rgba(255,255,255,0.03);
}
/* ---------- Landscape gallery — for horizontal screenshots ---------- */
.swipe-gallery--landscape .swipe-gallery__slide {
    flex: 0 0 520px;
    text-align: center;
}
.swipe-gallery--landscape .swipe-gallery__slide img {
    height: auto;
    max-height: 340px;
    object-fit: contain;
    border-radius: 12px;
    background: rgba(255,255,255,0.03);
}
.swipe-gallery__caption {
    display: block;
    margin-top: 10px;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    text-align: center;
}

/* ---------- FEEDBACK 8: Campaign Cards (sub-sections) ---------- */
.cs-campaigns__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
}
.cs-campaign-card {
    background-color: rgba(255,255,255,0.04);
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
}
.cs-campaign-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,14,0.4) 0%, rgba(10,10,14,0.85) 100%);
    transition: background 0.3s;
    z-index: 1;
}
.cs-campaign-card__inner {
    position: relative;
    z-index: 2;
    padding: 32px;
    display: flex;
    flex-direction: column;
    height: 100%;
}
.cs-campaign-card:hover {
    border-color: rgba(0,255,136,0.4);
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(0,255,136,0.1);
}
.cs-campaign-card:hover .cs-campaign-card__overlay {
    background: linear-gradient(180deg, rgba(10,10,14,0.3) 0%, rgba(10,10,14,0.75) 100%);
}
.cs-campaign-card__badge {
    font-size: 2rem;
    margin-bottom: 16px;
}
.cs-campaign-card__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
}
.cs-campaign-card__date {
    font-size: 0.8rem;
    color: #00ff88;
    margin-bottom: 12px;
    font-weight: 600;
}
.cs-campaign-card__desc {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
    flex: 1;
    margin-bottom: 16px;
}
.cs-campaign-card__cta {
    font-size: 0.85rem;
    color: #00ff88;
    font-weight: 600;
    transition: letter-spacing 0.3s;
}
.cs-campaign-card:hover .cs-campaign-card__cta {
    letter-spacing: 1px;
}

/* ---------- Campaign Modal ---------- */
.cs-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
}
.cs-modal--active {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: modalFadeIn 0.35s ease;
}
@keyframes modalFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}
.cs-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
}
.cs-modal__content {
    position: relative;
    background: #0a0a0e;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    max-width: 900px;
    width: 90vw;
    max-height: 85vh;
    overflow-y: auto;
    padding: 48px 40px;
    z-index: 1;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,255,136,0.3) transparent;
    animation: modalSlideUp 0.4s ease;
}
@keyframes modalSlideUp {
    from { transform: translateY(40px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}
.cs-modal__content::-webkit-scrollbar { width: 6px; }
.cs-modal__content::-webkit-scrollbar-track { background: transparent; }
.cs-modal__content::-webkit-scrollbar-thumb { background: rgba(0,255,136,0.3); border-radius: 3px; }
.cs-modal__close {
    position: sticky;
    top: 0;
    float: right;
    background: rgba(255,255,255,0.1);
    border: none;
    color: #fff;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 1rem;
    cursor: pointer;
    z-index: 2;
    transition: background 0.3s;
}
.cs-modal__close:hover { background: rgba(255,255,255,0.2); }

/* ---------- Campaign inner styles (for modals) ---------- */
.cs-campaign__header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
}
.cs-campaign__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
}
.cs-campaign__date {
    font-size: 0.85rem;
    color: #00ff88;
    font-weight: 600;
}
.cs-campaign__objectives { margin-bottom: 32px; }
.cs-campaign__objectives h4 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 16px;
    font-weight: 600;
}
.cs-objectives__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
}
.cs-objective {
    display: flex;
    gap: 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 16px;
}
.cs-objective__num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #00ff88;
    flex-shrink: 0;
}
.cs-objective p { font-size: 0.85rem; color: rgba(255,255,255,0.7); line-height: 1.5; }

/* Campaign Pillars Row */
.cs-campaign__pillars { margin-bottom: 32px; }
.cs-campaign__pillars h4 { font-size: 1rem; color: #fff; margin-bottom: 16px; font-weight: 600; }
.cs-pillars-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.cs-pillar-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 24px;
    transition: border-color 0.3s;
}
.cs-pillar-card:hover { border-color: rgba(0,255,136,0.3); }
.cs-pillar-card__icon { font-size: 1.5rem; display: block; margin-bottom: 12px; }
.cs-pillar-card h5 { font-size: 0.95rem; color: #fff; margin-bottom: 8px; }
.cs-pillar-card p { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.5; margin-bottom: 12px; }
.cs-pillar-card__goal {
    display: inline-block;
    background: rgba(0,255,136,0.12);
    color: #00ff88;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* Timeline Phases */
.cs-campaign__timeline { margin-bottom: 32px; }
.cs-campaign__timeline h4 { font-size: 1rem; color: #fff; margin-bottom: 16px; font-weight: 600; }
.cs-phase-timeline { display: flex; flex-direction: column; gap: 24px; }
.cs-phase {
    border-left: 3px solid rgba(0,255,136,0.3);
    padding-left: 24px;
}
.cs-phase__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
}
.cs-phase__badge {
    background: rgba(0,255,136,0.15);
    color: #00ff88;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
}
.cs-phase__badge--live { background: rgba(255,100,100,0.15); color: #ff6464; }
.cs-phase__badge--post { background: rgba(100,150,255,0.15); color: #6496ff; }
.cs-phase__dates { font-size: 0.8rem; color: rgba(255,255,255,0.4); }
.cs-phase__goal {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 12px;
    font-style: italic;
}

/* Amplification */
.cs-campaign__amplification { margin-bottom: 32px; }
.cs-campaign__amplification h4 { font-size: 1rem; color: #fff; margin-bottom: 16px; font-weight: 600; }
.cs-amp__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
.cs-amp__item {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 16px;
}
.cs-amp__item h5 { font-size: 0.9rem; color: #fff; margin-bottom: 6px; }
.cs-amp__item p { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.4; }

/* Campaign Results */
.cs-campaign__results {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 32px;
}
.cs-campaign__result {
    text-align: center;
    padding: 24px;
    background: rgba(0,255,136,0.06);
    border: 1px solid rgba(0,255,136,0.15);
    border-radius: 14px;
}
.cs-campaign__result .cs-results__number {
    font-size: 2rem;
}

/* Đồng Ca Learnings */
.cs-campaign__learnings { margin-bottom: 24px; }
.cs-campaign__learnings h4 { font-size: 1rem; color: #fff; margin-bottom: 12px; font-weight: 600; }
.cs-campaign__results-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.cs-campaign__results-list li {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.5;
    padding: 10px 16px;
    background: rgba(255,255,255,0.03);
    border-radius: 8px;
}
.cs-campaign__constraint { margin-bottom: 24px; }
.cs-campaign__constraint h4 { font-size: 1rem; color: #fff; margin-bottom: 12px; font-weight: 600; }
.cs-campaign__constraint p { font-size: 0.85rem; color: rgba(255,255,255,0.6); line-height: 1.6; }

/* ---------- FEEDBACK 4: Đồng Ca Framework — "Xưa" square grid ---------- */
.cs-dongca__framework { margin-bottom: 32px; }
.cs-dongca__framework h4 { font-size: 1rem; color: #fff; margin-bottom: 20px; font-weight: 600; }
.cs-dongca__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}
.cs-dongca__col {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 24px;
}
.cs-dongca__col-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
}
.cs-dongca__col-desc {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    margin-bottom: 16px;
}
/* Square grid layout: 3x3 with center text "Đồng Ca" */
.cs-dongca__square-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 20px;
}
.cs-dongca__keyword {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 12px 8px;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.8);
    text-align: center;
    transition: border-color 0.3s, transform 0.3s;
}
.cs-dongca__keyword:hover {
    border-color: rgba(0,255,136,0.4);
    transform: scale(1.05);
}
.cs-dongca__center-text {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #ffd700;
    background: #cc0000;
    border: 2px solid #ff3333;
    border-radius: 12px;
    padding: 12px;
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
}
.cs-dongca__col-types {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.5;
}
.cs-dongca__chart-types {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.cs-dongca__type {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    padding: 8px 12px;
    background: rgba(255,255,255,0.03);
    border-radius: 8px;
    line-height: 1.4;
}

/* ---------- Takeaways ---------- */
.cs-takeaways {
    display: flex;
    flex-direction: column;
    gap: 16px;
}
.cs-takeaway {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    padding: 24px;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
}
.cs-takeaway:hover {
    border-color: rgba(0,255,136,0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
}
.cs-takeaway__num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #00ff88;
    flex-shrink: 0;
    opacity: 0.7;
}
.cs-takeaway__content h4 {
    font-size: 1rem;
    color: #fff;
    margin-bottom: 6px;
    font-weight: 600;
}
.cs-takeaway__content p {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.5;
}

/* ---------- Funnel Diagram ---------- */
.cs-funnel { display: flex; flex-direction: column; gap: 0; }
.cs-funnel__stage {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 28px;
    transition: border-color 0.3s;
}
.cs-funnel__stage:hover { border-color: rgba(0,255,136,0.3); }
.cs-funnel__stage-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
}
.cs-funnel__stage-header h4 {
    font-size: 1.05rem;
    color: #fff;
    font-weight: 600;
}
.cs-funnel__stage-body { display: flex; flex-direction: column; gap: 12px; }
.cs-funnel__items { display: flex; flex-direction: column; gap: 10px; }
.cs-funnel__item {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    padding-left: 16px;
    border-left: 2px solid rgba(0,255,136,0.25);
}
.cs-funnel__item strong { color: #fff; }
.cs-funnel__metrics {
    margin-top: 8px;
    padding: 8px 14px;
    background: rgba(0,255,136,0.06);
    border-radius: 8px;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
}
.cs-funnel__connector {
    text-align: center;
    font-size: 1.5rem;
    color: rgba(0,255,136,0.4);
    padding: 8px 0;
}

/* ---------- SWOT Grid ---------- */
.cs-swot { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px; }
.cs-swot__card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 24px;
}
.cs-swot__card--s { border-color: rgba(0,255,136,0.2); }
.cs-swot__card--w { border-color: rgba(255,100,100,0.2); }
.cs-swot__card--o { border-color: rgba(100,200,255,0.2); }
.cs-swot__card--t { border-color: rgba(255,200,100,0.2); }
.cs-swot__card h4 { font-size: 1rem; color: #fff; margin-bottom: 12px; font-weight: 600; }
.cs-swot__card ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px; }
.cs-swot__card li {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
}
.cs-swot__card li::before { content: '→'; position: absolute; left: 0; color: rgba(255,255,255,0.3); }

/* ---------- Roadmap Timeline ---------- */
.cs-roadmap { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px; }
.cs-roadmap__phase {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 24px;
    position: relative;
}
.cs-roadmap__phase-badge {
    display: inline-block;
    background: rgba(0,255,136,0.12);
    color: #00ff88;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 12px;
}
.cs-roadmap__phase h4 { font-size: 0.95rem; color: #fff; margin-bottom: 12px; font-weight: 600; }
.cs-roadmap__phase ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 6px; }
.cs-roadmap__phase li { font-size: 0.8rem; color: rgba(255,255,255,0.6); line-height: 1.5; padding-left: 14px; position: relative; }
.cs-roadmap__phase li::before { content: '•'; position: absolute; left: 0; color: #00ff88; }

/* ---------- Key Issues Numbered ---------- */
.cs-issues { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 32px; }
.cs-issue {
    display: flex;
    gap: 16px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 20px;
}
.cs-issue__num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: rgba(255,100,100,0.6);
    flex-shrink: 0;
}
.cs-issue h4 { font-size: 0.9rem; color: #fff; margin-bottom: 6px; font-weight: 600; }
.cs-issue p { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.5; }

/* ---------- Brand Identity Showcase ---------- */
.cs-brand-showcase { margin-bottom: 32px; }
.cs-brand-showcase__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
.cs-brand-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 32px;
    text-align: center;
}
.cs-brand-card img {
    max-width: 200px;
    margin: 0 auto 20px;
    border-radius: 12px;
}
.cs-brand-card h4 { font-size: 1rem; color: #fff; margin-bottom: 8px; }
.cs-brand-card p { font-size: 0.85rem; color: rgba(255,255,255,0.55); line-height: 1.5; }

/* ---------- Color Palette ---------- */
.cs-palette { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
.cs-palette__swatch {
    width: 80px;
    height: 80px;
    border-radius: 12px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 8px;
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.1);
}

/* ---------- Product Mockup Grid ---------- */
.cs-mockup-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px; }
.cs-mockup-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
}
.cs-mockup-card:hover { border-color: rgba(0,255,136,0.3); transform: translateY(-4px); }
.cs-mockup-card img { width: 100%; height: 250px; object-fit: cover; }
.cs-mockup-card__info { padding: 16px; }
.cs-mockup-card__info h5 { font-size: 0.9rem; color: #fff; margin-bottom: 4px; }
.cs-mockup-card__info p { font-size: 0.75rem; color: rgba(255,255,255,0.45); }

/* ---------- Freelance Section (index.html) ---------- */
.freelance-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap, 24px); }

/* ---------- Footer CTA (Hero-style) ---------- */
.cs-cta {
    position: relative;
    padding: 100px 0;
    text-align: center;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
}
.cs-cta__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
        rgba(10, 10, 14, 0.5) 0%,
        rgba(10, 10, 14, 0.75) 100%);
    z-index: 1;
}
.cs-cta .container {
    position: relative;
    z-index: 2;
}
.cs-cta__credit {
    font-size: 1rem;
    color: rgba(255,255,255,0.8);
    margin-bottom: 28px;
    line-height: 1.6;
}
.cs-cta__credit strong {
    color: #fff;
}
.cs-cta__actions {
    display: flex;
    gap: 16px;
    justify-content: center;
}

/* ---------- Responsive ---------- */
@media (max-width: 768px) {
    .cs-overview__grid { grid-template-columns: repeat(2, 1fr); }
    .cs-results__grid { grid-template-columns: 1fr; }
    .cs-results__highlights { grid-template-columns: 1fr; }
    .cs-challenges__grid--row { grid-template-columns: repeat(2, 1fr); }
    .cs-comparison__row { grid-template-columns: 1fr; }
    .cs-objectives__grid { grid-template-columns: 1fr; }
    .cs-pillars-row { grid-template-columns: 1fr; }
    .cs-dongca__columns { grid-template-columns: 1fr; }
    .cs-amp__grid { grid-template-columns: 1fr; }
    .cs-campaign__results { grid-template-columns: 1fr; }
    .cs-campaigns__cards { grid-template-columns: 1fr; }
    .cs-growth__content { grid-template-columns: 1fr; }
    .cs-modal__content { padding: 24px 20px; width: 95vw; max-height: 90vh; }
    .cs-swot { grid-template-columns: 1fr; }
    .cs-roadmap { grid-template-columns: 1fr; }
    .cs-issues { grid-template-columns: 1fr; }
    .cs-brand-showcase__grid { grid-template-columns: 1fr; }
    .cs-mockup-grid { grid-template-columns: 1fr; }
    .freelance-grid { grid-template-columns: 1fr; }
    .cs-comparison__row[style] { grid-template-columns: 1fr !important; }
    .cs-palette__swatch { width: 60px; height: 60px; }
}
